# Copy this file to `.env.local` and fill in the values for local development.
# `.env.local` is gitignored and must not be committed.

# ---------- Supabase ----------
# Local dev defaults (supabase start の出力を使用)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Stripe ----------
# Stripe Dashboard (test mode) > Developers > API keys から取得
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret — ローカルでは `stripe listen --print-secret` で取得
# 開発中は別ターミナルで以下を起動しておくこと:
#   stripe listen --forward-to http://localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Customer Portal Configuration ID (カード情報更新 + 請求履歴 のみ有効にする)
# 作成方法: stripe billing_portal configurations create ... (README 参照)
STRIPE_PORTAL_CONFIGURATION_ID=bpc_1TKxS2R1gPIkMTMdlqP8fQuL

# Price IDs — 基本プラン (月額 subscription)
STRIPE_PRICE_INDIVIDUAL=price_1TKxQtR1gPIkMTMdfnPJyeqA         # ¥3,800 / 月
STRIPE_PRICE_SMALL=price_1TKxR9R1gPIkMTMdk7PgtbDU               # ¥14,800 / 月
STRIPE_PRICE_CORPORATE=price_1TKxRBR1gPIkMTMdEForQEYN           # ¥48,000 / 月
STRIPE_PRICE_CORPORATE_PREMIUM=price_1TKxRCR1gPIkMTMdYfXOHrGR   # ¥148,000 / 月

# Price IDs — 初期費用 (one-time)
STRIPE_PRICE_INITIAL_FEE=price_1TKxRDR1gPIkMTMdr5ZBuJLW         # ¥20,000 (初回申込時のみ)

# Price IDs — 補償オプション (月額 subscription)
STRIPE_PRICE_COMPENSATION_5000=price_1TKxRER1gPIkMTMdp3d72SoJ   # ¥5,000 / 月
STRIPE_PRICE_COMPENSATION_9800=price_1TKxRGR1gPIkMTMdvucU6rCX   # ¥9,800 / 月

# Price IDs — 単発オプション (one-time)
STRIPE_PRICE_URGENT=price_1TKxRHR1gPIkMTMdppzkE3bN              # ¥20,000 (7日間有効)
STRIPE_PRICE_VIDEO=price_1TKxRIR1gPIkMTMdieuQMXAI               # ¥100,000

# ---------- iron-session ----------
# fee=free Cookie の暗号化キー (32文字以上)。生成: `openssl rand -hex 32`
SESSION_SECRET=

# ---------- Resend (email) ----------
# https://resend.com > API Keys から取得
RESEND_API_KEY=re_xxx
